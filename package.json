{
  "name": "cinejelly-seedance-ultimate-director",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "description": "Production-grade agentic video pipeline for Seedance 2.0 through Atlas Cloud.",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "tsc -p tsconfig.json",
    "preflight": "npm run build && node dist/application/preflight-entrypoint.js",
    "start": "node dist/api/server.js"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "typescript": "^5.8.0"
  }
}
