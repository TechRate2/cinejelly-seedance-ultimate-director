{
  "name": "cinejelly-seedance-ultimate-director",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "description": "Production-grade agentic video pipeline for Seedance 2.0 through Atlas Cloud.",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "setup:local": "node scripts/setup-local-env.mjs",
    "setup:windows": "powershell -ExecutionPolicy Bypass -File scripts/setup-windows.ps1",
    "doctor": "node scripts/run-doctor.mjs",
    "typecheck": "tsc --noEmit",
    "build": "tsc -p tsconfig.json",
    "preflight": "npm run build && node --env-file-if-exists=.env dist/application/preflight-entrypoint.js",
    "validation:readiness": "npm run build && node --env-file-if-exists=.env dist/application/validation-readiness-entrypoint.js",
    "validation:create-request": "node scripts/create-validation-request.mjs",
    "validation:local-smoke": "node scripts/run-local-validation-smoke.mjs",
    "validation:release-audit": "node scripts/run-release-audit.mjs",
    "validation:render-request": "npm run build && node --env-file-if-exists=.env dist/application/render-request-validation-entrypoint.js",
    "validation:paid-render": "npm run build && node --env-file-if-exists=.env dist/application/paid-render-validation-entrypoint.js",
    "validate:artifacts": "npm run build && node --env-file-if-exists=.env dist/application/artifact-validation-entrypoint.js",
    "start": "node --env-file-if-exists=.env dist/api/server.js"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "typescript": "^5.8.0"
  }
}
