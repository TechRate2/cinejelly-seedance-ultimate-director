{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cinejelly.local/schemas/phase6-paid-render-validation-report.schema.json",
  "title": "CineJelly Phase 6 Paid Render Validation Report",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "generatedAt", "status", "sourcePatternOrigins", "readiness", "nextActions"],
  "properties": {
    "schemaVersion": { "const": "cinejelly.phase6.paid-render-validation.v1" },
    "generatedAt": { "type": "string", "format": "date-time" },
    "status": {
      "enum": [
        "blocked_by_readiness",
        "blocked_by_readiness_warnings",
        "completed",
        "completed_with_artifact_validation_warning",
        "completed_with_artifact_validation_failure",
        "render_failed",
        "failed"
      ]
    },
    "sourcePatternOrigins": {
      "type": "array",
      "items": { "type": "string" }
    },
    "requestId": { "type": "string" },
    "readiness": { "type": "object" },
    "artifactBundle": {
      "type": "object",
      "additionalProperties": false,
      "required": ["projectId", "manifestFileName", "entries"],
      "properties": {
        "projectId": { "type": "string" },
        "manifestFileName": { "const": "manifest.json" },
        "entries": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": true,
            "required": ["kind", "fileName", "contentType", "byteSize", "sha256", "createdAt"],
            "properties": {
              "kind": { "type": "string" },
              "fileName": { "type": "string" },
              "contentType": { "const": "application/json" },
              "byteSize": { "type": "integer", "minimum": 0 },
              "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
              "createdAt": { "type": "string", "format": "date-time" }
            }
          }
        }
      }
    },
    "artifactValidation": {
      "type": "object",
      "additionalProperties": true,
      "required": ["status", "checkedAt", "checks"],
      "properties": {
        "status": { "enum": ["pass", "warn", "fail"] },
        "checkedAt": { "type": "string", "format": "date-time" },
        "projectId": { "type": "string" },
        "checks": {
          "type": "array",
          "items": { "type": "object" }
        }
      }
    },
    "costLedgerEntryCount": { "type": "integer", "minimum": 0 },
    "estimatedCostUsd": { "type": "number", "minimum": 0 },
    "actualCostUsd": { "type": "number", "minimum": 0 },
    "error": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "message"],
      "properties": {
        "name": { "type": "string" },
        "message": { "type": "string" }
      }
    },
    "nextActions": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
