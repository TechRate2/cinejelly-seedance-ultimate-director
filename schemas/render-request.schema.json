{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cinejelly.local/schemas/render-request.schema.json",
  "title": "CineJelly Render Request",
  "description": "Operator-supplied request contract for /v1/render, /v1/render-jobs, and validation:paid-render. Runtime TypeScript admission remains authoritative.",
  "type": "object",
  "additionalProperties": false,
  "required": ["userInput"],
  "properties": {
    "userInput": {
      "type": "string",
      "minLength": 1,
      "maxLength": 24000
    },
    "settings": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "tier": { "enum": ["fast", "standard"] },
        "resolution": { "enum": ["480p", "720p", "1080p"] },
        "qualityMode": { "enum": ["economy", "standard", "high", "ultimate"] },
        "ratio": { "enum": ["adaptive", "21:9", "16:9", "4:3", "1:1", "3:4", "9:16"] },
        "durationTargetSeconds": { "type": "number", "minimum": 1, "maximum": 480 },
        "audioMode": { "enum": ["none", "native", "guided", "post", "hybrid"] },
        "watermark": { "type": "boolean" },
        "returnLastFrame": { "type": "boolean" },
        "maxCostUsd": { "type": "number", "minimum": 0 }
      }
    },
    "references": {
      "type": "array",
      "maxItems": 24,
      "items": { "$ref": "#/$defs/reference" }
    },
    "metadata": {
      "type": "object",
      "maxProperties": 50,
      "additionalProperties": {
        "type": "string",
        "maxLength": 500
      },
      "propertyNames": {
        "type": "string",
        "maxLength": 80
      }
    },
    "outputPath": { "$ref": "#/$defs/operatorPath" },
    "workDirectory": { "$ref": "#/$defs/operatorPath" },
    "artifactDirectory": { "$ref": "#/$defs/operatorPath" },
    "captionCues": {
      "type": "array",
      "maxItems": 600,
      "items": { "$ref": "#/$defs/captionCue" }
    },
    "captionOptions": { "$ref": "#/$defs/captionOptions" },
    "audioTracks": {
      "type": "array",
      "maxItems": 16,
      "items": { "$ref": "#/$defs/audioTrack" }
    },
    "audioMixOptions": { "$ref": "#/$defs/audioMixOptions" },
    "generatedAudioIntents": {
      "type": "array",
      "maxItems": 32,
      "items": { "$ref": "#/$defs/generatedAudioIntent" }
    },
    "frameSamplingOptions": { "$ref": "#/$defs/frameSamplingOptions" },
    "transitionSettings": { "$ref": "#/$defs/transitionSettings" },
    "semanticVisualInspectionOptions": { "$ref": "#/$defs/semanticVisualInspectionOptions" },
    "sourceVideoAnalysis": {
      "type": "object",
      "description": "Bounded source-video deconstruction. Runtime admission performs deeper shape checks."
    }
  },
  "$defs": {
    "operatorPath": {
      "type": "string",
      "minLength": 1,
      "maxLength": 500,
      "not": {
        "pattern": "[\\u0000-\\u001f\\u007f]"
      }
    },
    "safeHttpsOrAssetUri": {
      "type": "string",
      "pattern": "^(https://[^\\s]+|asset://[^\\s?#]+)$"
    },
    "reference": {
      "type": "object",
      "additionalProperties": true,
      "required": ["kind", "uri"],
      "properties": {
        "kind": {
          "enum": [
            "image",
            "video",
            "audio",
            "first_frame",
            "last_frame",
            "identity",
            "product",
            "environment",
            "motion",
            "camera",
            "style",
            "source_video_structure"
          ]
        },
        "uri": { "$ref": "#/$defs/safeHttpsOrAssetUri" },
        "label": { "type": "string", "maxLength": 160 },
        "role": { "type": "string", "maxLength": 160 }
      }
    },
    "captionCue": {
      "type": "object",
      "additionalProperties": false,
      "required": ["startSecond", "endSecond", "text"],
      "properties": {
        "startSecond": { "type": "number", "minimum": 0 },
        "endSecond": { "type": "number", "minimum": 0 },
        "text": { "type": "string", "minLength": 1, "maxLength": 500 },
        "speaker": { "type": "string", "maxLength": 120 }
      }
    },
    "captionOptions": {
      "type": "object",
      "additionalProperties": false,
      "required": ["enabled", "format", "burnIn"],
      "properties": {
        "enabled": { "type": "boolean" },
        "format": { "enum": ["srt", "vtt"] },
        "burnIn": { "type": "boolean" },
        "language": { "type": "string", "maxLength": 40 },
        "font": { "type": "string", "maxLength": 120 },
        "fontSize": { "type": "number", "minimum": 8, "maximum": 96 }
      }
    },
    "audioTrack": {
      "type": "object",
      "additionalProperties": false,
      "required": ["trackId", "sourceUrlOrPath", "role", "volume"],
      "properties": {
        "trackId": { "type": "string", "minLength": 1, "maxLength": 160 },
        "sourceUrlOrPath": { "$ref": "#/$defs/safeHttpsOrAssetUri" },
        "role": { "enum": ["music", "narration", "ambience", "sfx"] },
        "volume": { "type": "number", "minimum": 0, "maximum": 2 }
      }
    },
    "audioMixOptions": {
      "type": "object",
      "additionalProperties": false,
      "required": ["enabled", "mode", "originalVolume", "outputBitrate"],
      "properties": {
        "enabled": { "type": "boolean" },
        "mode": { "enum": ["mix", "replace"] },
        "originalVolume": { "type": "number", "minimum": 0, "maximum": 2 },
        "outputBitrate": { "type": "string", "pattern": "^([1-9]\\d{1,3})k$" }
      }
    },
    "generatedAudioIntent": {
      "type": "object",
      "additionalProperties": false,
      "required": ["intentId", "kind", "prompt"],
      "properties": {
        "intentId": { "type": "string", "minLength": 1, "maxLength": 160 },
        "kind": { "enum": ["tts_narration", "bgm", "ambience", "sfx"] },
        "prompt": { "type": "string", "minLength": 1, "maxLength": 1000 },
        "startSecond": { "type": "number", "minimum": 0, "maximum": 600 },
        "endSecond": { "type": "number", "minimum": 0, "maximum": 600 },
        "durationSeconds": { "type": "number", "minimum": 0, "maximum": 600 },
        "language": { "type": "string", "maxLength": 160 },
        "voiceStyle": { "type": "string", "maxLength": 160 },
        "mood": { "type": "string", "maxLength": 160 },
        "volume": { "type": "number", "minimum": 0, "maximum": 2 },
        "providerPreference": { "type": "string", "maxLength": 160 }
      }
    },
    "frameSamplingOptions": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean" },
        "maxFrames": { "type": "integer", "minimum": 1, "maximum": 60 },
        "intervalSeconds": { "type": "number", "minimum": 0.1, "maximum": 60 }
      }
    },
    "transitionSettings": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean" },
        "kind": { "enum": ["fade", "wipeleft", "wiperight", "slideleft", "slideright"] },
        "durationSeconds": { "type": "number", "minimum": 0, "maximum": 3 },
        "targetHeight": { "enum": [480, 720, 1080] }
      }
    },
    "semanticVisualInspectionOptions": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean" },
        "maxFrames": { "type": "integer", "minimum": 1, "maximum": 60 },
        "expectations": {
          "type": "array",
          "maxItems": 32,
          "items": { "type": "string", "minLength": 1, "maxLength": 300 }
        }
      }
    }
  }
}
